@model StudentManagement.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <h2 class="fw-bold">@Model.CourseName</h2>

            <hr />

            <div class="row">

                <div class="col-md-4">

                    <h6 class="text-muted">Department</h6>

                    <p>@Model.Department</p>

                </div>

                <div class="col-md-4">

                    <h6 class="text-muted">Duration</h6>

                    <p>@Model.Duration</p>

                </div>

            </div>

            <h6 class="text-muted">Description</h6>

            <p>@Model.Description</p>

        </div>

    </div>

    <div class="row">

        <!-- Teachers -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">

                        Teachers (@Model.Teachers.Count)

                    </h5>

                </div>

                <div class="card-body">

                    @if (Model.Teachers.Any())
                    {
                        <table class="table table-hover">

                            <thead>

                                <tr>

                                    <th>Name</th>

                                    <th>Email</th>

                                </tr>

                            </thead>

                            <tbody>

                            @foreach(var teacher in Model.Teachers)
                            {
                                <tr>

                                    <td>@teacher.Name</td>

                                    <td>@teacher.Email</td>

                                </tr>
                            }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <p class="text-muted">
                            No teachers assigned.
                        </p>
                    }

                </div>

            </div>

        </div>

        <!-- Students -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">

                        Students (@Model.Students.Count)

                    </h5>

                </div>

                <div class="card-body">

                    @if (Model.Students.Any())
                    {
                        <table class="table table-hover">

                            <thead>

                                <tr>

                                    <th>Name</th>

                                    <th>Email</th>

                                </tr>

                            </thead>

                            <tbody>

                            @foreach(var student in Model.Students)
                            {
                                <tr>

                                    <td>@student.Name</td>

                                    <td>@student.Email</td>

                                </tr>
                            }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <p class="text-muted">
                            No students enrolled.
                        </p>
                    }

                </div>

            </div>

        </div>

    </div>

</div>