@model IEnumerable<StudentManagement.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">Courses</h1>
            <p class="text-muted mb-0">
                Manage all courses offered by the institute.
            </p>
        </div>

        <a asp-action="Create"
           class="btn btn-info text-white px-4 py-2 shadow-sm">

            <i class="bi bi-plus-circle me-2"></i>

            Add Course

        </a>

    </div>

    <!-- Table Card -->

    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>ID</th>
                            <th>Course Name</th>
                            <th>Department</th>
                            <th>Duration</th>
                            <th>Description</th>
                            <th class="text-center">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var course in Model)
                        {
                            <tr>

                                <td>@course.CourseId</td>

                                <td>

                                    <div class="d-flex align-items-center">

                                        <div class="rounded-circle bg-info text-white d-flex justify-content-center align-items-center me-3"
                                             style="width:40px;height:40px;">

                                            @course.CourseName.Substring(0,1)

                                        </div>

                                        <strong>@course.CourseName</strong>

                                    </div>

                                </td>

                                <td>

                                    <span class="badge bg-info-subtle text-info">

                                        @course.Department

                                    </span>

                                </td>

                                <td>

                                    <span class="badge bg-light text-dark border">

                                        @course.Duration

                                    </span>

                                </td>

                                <td style="max-width:300px;">

                                    @course.Description

                                </td>

                               <td class="text-center">

    <!-- View -->

    <a asp-action="Details"
       asp-route-id="@course.CourseId"
       class="btn btn-outline-primary btn-sm me-2"
       title="View Course">

        <i class="bi bi-eye"></i>

    </a>

    <!-- Edit -->

    <a asp-action="Edit"
       asp-route-id="@course.CourseId"
       class="btn btn-outline-info btn-sm me-2"
       title="Edit">

        <i class="bi bi-pencil-square"></i>

    </a>

    <!-- Delete -->

    @if (User.IsInRole("Admin"))
    {
        <form asp-action="Delete"
              asp-route-id="@course.CourseId"
              method="post"
              style="display:inline;">

            <button type="submit"
                    class="btn btn-outline-danger btn-sm"
                    title="Delete"
                    onclick="return confirm('Delete this course?')">

                <i class="bi bi-trash"></i>

            </button>

        </form>
    }

</td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>