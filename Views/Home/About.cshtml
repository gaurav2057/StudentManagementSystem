@{
    ViewData["Title"] = "About";
}

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="display-4 fw-bold text-primary">
            About Student Management System
        </h1>

        <p class="lead text-muted">
            A modern web application for efficiently managing students, teachers and courses.
        </p>

    </div>

    <div class="card shadow-lg border-0">

        <div class="card-body p-5">

            <h3 class="mb-4">Project Overview</h3>

            <p>
                The Student Management System is a web-based application
                developed to simplify the management of educational institutions.
                It allows administrators to manage students, teachers and courses
                through an easy-to-use interface.
            </p>

            <hr class="my-4">

            <h3 class="mb-4">Features</h3>

            <div class="row">

                <div class="col-md-6">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">✅ Student Management</li>
                        <li class="list-group-item">✅ Teacher Management</li>
                        <li class="list-group-item">✅ Course Management</li>
                        <li class="list-group-item">✅ Secure Login & Logout</li>

                    </ul>

                </div>

                <div class="col-md-6">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">✅ Role-Based Authorization</li>
                        <li class="list-group-item">✅ Dashboard</li>
                        <li class="list-group-item">✅ Responsive Design</li>
                        <li class="list-group-item">✅ CRUD Operations</li>

                    </ul>

                </div>

            </div>

            <hr class="my-4">

            <h3 class="mb-4">Technologies Used</h3>

            <div class="row text-center">

                <div class="col-md-3">
                    <h5>ASP.NET Core MVC</h5>
                </div>

                <div class="col-md-3">
                    <h5>Dapper ORM</h5>
                </div>

                <div class="col-md-3">
                    <h5>SQL Server</h5>
                </div>

                <div class="col-md-3">
                    <h5>Bootstrap 5</h5>
                </div>

            </div>

        </div>

    </div>

</div>