@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="bg-primary text-white rounded-4 shadow-lg p-5 mb-5">

    <div class="text-center">

        <h1 class="display-3 fw-bold">
            Student Management System
        </h1>

        <p class="lead mt-3">
            Manage Students, Teachers and Courses efficiently in one place.
        </p>

    </div>

</div>

<!-- Quick Access -->
<div class="text-center mb-4">

    <h2 class="fw-bold">Quick Access</h2>

    <p class="text-muted">
        Select a module to manage your college data.
    </p>

</div>

<div class="row g-4 mb-5">

    <!-- Students -->
    <div class="col-md-4">

        <a asp-controller="Student"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card h-100 shadow feature-card student-card">

                <div class="card-body text-center p-5">

                    <i class="bi bi-mortarboard-fill display-1 text-primary"></i>

                    <h3 class="mt-4 fw-bold">
                        Students
                    </h3>

                    <p class="text-muted">
                        Add, update, search and manage student records.
                    </p>

                    <button class="btn btn-primary px-4">
                        Manage Students
                    </button>

                </div>

            </div>

        </a>

    </div>

    <!-- Teachers -->
    <div class="col-md-4">

        <a asp-controller="Teacher"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card h-100 shadow feature-card teacher-card">

                <div class="card-body text-center p-5">

                    <i class="bi bi-person-workspace display-1 text-success"></i>

                    <h3 class="mt-4 fw-bold">
                        Teachers
                    </h3>

                    <p class="text-muted">
                        Maintain faculty information and department details.
                    </p>

                    <button class="btn btn-success px-4">
                        Manage Teachers
                    </button>

                </div>

            </div>

        </a>

    </div>

    <!-- Courses -->
    <div class="col-md-4">

        <a asp-controller="Course"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card h-100 shadow feature-card course-card">

                <div class="card-body text-center p-5">

                    <i class="bi bi-book-half display-1 text-warning"></i>

                    <h3 class="mt-4 fw-bold">
                        Courses
                    </h3>

                    <p class="text-muted">
                        Create and manage available college courses.
                    </p>

                    <button class="btn btn-warning px-4">
                        Manage Courses
                    </button>

                </div>

            </div>

        </a>

    </div>

</div>

<hr class="my-5">

<!-- Statistics -->

<div class="text-center mb-4">

    <h2 class="fw-bold">
        System Statistics
    </h2>

    <p class="text-muted">
        Overview of the management system.
    </p>

</div>

<div class="row g-4 mb-5">

    <div class="col-md-4">

        <div class="card bg-primary text-white shadow border-0">

            <div class="card-body text-center py-4">

                <i class="bi bi-people-fill display-4"></i>

                <h5 class="mt-3">
                    Users
                </h5>

                <h2 class="fw-bold">
                    3
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card bg-success text-white shadow border-0">

            <div class="card-body text-center py-4">

                <i class="bi bi-building display-4"></i>

                <h5 class="mt-3">
                    Cities
                </h5>

                <h2 class="fw-bold">
                    5
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card bg-warning shadow border-0">

            <div class="card-body text-center py-4">

                <i class="bi bi-award-fill display-4"></i>

                <h5 class="mt-3">
                    Graduates
                </h5>

                <h2 class="fw-bold">
                    250
                </h2>

            </div>

        </div>

    </div>

</div>

<!-- Features -->

<div class="text-center mb-4">

    <h2 class="fw-bold">
        Why Choose Our System?
    </h2>

</div>

<div class="row text-center">

    <div class="col-md-3">

        <i class="bi bi-check-circle-fill text-success display-5"></i>

        <h5 class="mt-3">
            Student Management
        </h5>

    </div>

    <div class="col-md-3">

        <i class="bi bi-check-circle-fill text-success display-5"></i>

        <h5 class="mt-3">
            Teacher Management
        </h5>

    </div>

    <div class="col-md-3">

        <i class="bi bi-check-circle-fill text-success display-5"></i>

        <h5 class="mt-3">
            Course Management
        </h5>

    </div>

    <div class="col-md-3">

        <i class="bi bi-shield-lock-fill text-primary display-5"></i>

        <h5 class="mt-3">
            Secure Authentication
        </h5>

    </div>

</div>