@model IEnumerable<StudentManagement.Models.Teacher>

@{
    ViewData["Title"] = "Teachers";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h1 class="fw-bold mb-1">Teachers</h1>
            <p class="text-muted mb-0">
                Manage all faculty records in one place.
            </p>
        </div>

        <a asp-action="Create"
           class="btn btn-success px-4 py-2 shadow-sm">

            <i class="bi bi-plus-circle me-2"></i>

            Add Teacher

        </a>

    </div>

    <!-- Table Card -->

    <div class="card border-0 shadow-sm">

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>ID</th>
                            <th>Name</th>
                            <th>Department</th>
                            <th>Qualification</th>
                            <th>Email</th>
                            <th class="text-center">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var teacher in Model)
                        {

                            <tr>

                                <td>@teacher.TeacherId</td>

                                <td>

                                    <div class="d-flex align-items-center">

                                        <div class="rounded-circle bg-success text-white d-flex justify-content-center align-items-center me-3"
                                             style="width:40px;height:40px;">

                                            @teacher.Name.Substring(0,1)

                                        </div>

                                        <strong>
                                            @teacher.Name
                                        </strong>

                                    </div>

                                </td>

                                <td>

                                    <span class="badge bg-success-subtle text-success">

                                        @teacher.Department

                                    </span>

                                </td>

                                <td>@teacher.Qualification</td>

                                <td>@teacher.Email</td>

                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@teacher.TeacherId"
                                       class="btn btn-outline-success btn-sm me-2">

                                        <i class="bi bi-pencil-square"></i>

                                    </a>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-action="Delete"
                                              asp-route-id="@teacher.TeacherId"
                                              method="post"
                                              style="display:inline;">

                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Delete this teacher?')">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </form>
                                    }

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>